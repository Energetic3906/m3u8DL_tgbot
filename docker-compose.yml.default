version: '3'
services:
  m3u8dl-bot:
    container_name: m3u8dl-bot
    build: .
    environment:
      - APP_ID=<your_app_id>
      - APP_HASH=<your_app_hash>
      - TOKEN=<your_bot_token>
      - PREMIUM=False
      - AUTHORIZED_USERS=<your_user_id>
    volumes:
      - ./sessions:/app/sessions
      - ./cookies:/app/cookies
      - ./tmp:/tmp/m3u8D
    stdin_open: true
    tty: true
    restart: always
