version: '3'
services:
  m3u8dl-bot:
    container_name: m3u8dl-bot
    build: .
    environment:
      - APP_ID=<your_app_id>
      - APP_HASH=<your_app_hash>
      - TOKEN=<your_bot_token>
      - PREMIUM=False
      - AUTHORIZED_USERS=<your_user_id>
    volumes:
      - ./sessions/ytdl-main.session:/app/ytdl-main.session
      - ./sessions/app_user.session:/app/app_user.session
      - /tmp/m3u8D:/tmp/m3u8D
    stdin_open: true
    tty: true
    restart: always
